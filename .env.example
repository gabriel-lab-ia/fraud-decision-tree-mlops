APP_NAME=fraud-decision-tree-mlops
APP_ENV=development
API_KEY=
ENABLE_API_KEY_AUTH=false
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
MAX_BATCH_SIZE=100
ENABLE_PROMETHEUS_METRICS=true
MODEL_PATH=artifacts/models/decision_tree_model.joblib
MODEL_MANIFEST_PATH=artifacts/models/decision_tree_model.manifest.json
METRICS_PATH=reports/metrics.json
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=fraud_decision_tree_experiment
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=fraud_detection
MONGO_COLLECTION=prediction_events
